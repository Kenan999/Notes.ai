// ═══════════════════════════════════════════════════════════════
// Notes.ai — Database Schema
// Database: SQLite (kali_notes.db)
// Tables: 12
// ═══════════════════════════════════════════════════════════════

// ─── User Accounts ──────────────────────────────────────────

Table users {
  id INTEGER [pk, increment]
  email TEXT [not null, unique]
  password TEXT [not null]
  created_at DATETIME [default: `CURRENT_TIMESTAMP`]
}

// ─── Workspace ──────────────────────────────────────────────

Table ZWORKSPACE {
  Z_PK INTEGER [pk]
  ZID TEXT [not null]
  ZNAME TEXT [not null]
  ZACCENTCOLOR TEXT
  ZSERVERID TEXT
  ZSYNCSTATUS TEXT
  ZCREATIONDATE DATETIME
  ZUPDATEDAT DATETIME
  server_user_id INTEGER
}

Ref: ZWORKSPACE.server_user_id > users.id

// ─── Notebook ───────────────────────────────────────────────

Table ZNOTEBOOK {
  Z_PK INTEGER [pk]
  ZID TEXT [not null]
  ZNAME TEXT [not null]
  ZWORKSPACE INTEGER
  ZCOLORHEX TEXT
  ZSERVERID TEXT
  ZSYNCSTATUS TEXT
  ZCREATIONDATE DATETIME
  ZUPDATEDAT DATETIME
  server_user_id INTEGER
}

Ref: ZNOTEBOOK.ZWORKSPACE > ZWORKSPACE.Z_PK
Ref: ZNOTEBOOK.server_user_id > users.id

// ─── Page ───────────────────────────────────────────────────

Table ZPAGE {
  Z_PK INTEGER [pk]
  ZID TEXT [not null]
  ZTITLE TEXT
  ZINDEX INTEGER
  ZNOTEBOOK INTEGER
  ZDRAWINGDATA BLOB
  ZCONTENT TEXT
  ZOCRTEXT TEXT
  ZBACKGROUNDCOLORHEX TEXT
  ZBACKGROUNDSTYLE TEXT
  ZSERVERID TEXT
  ZSYNCSTATUS TEXT
  ZCREATIONDATE DATETIME
  ZUPDATEDAT DATETIME
  server_user_id INTEGER
}

Ref: ZPAGE.ZNOTEBOOK > ZNOTEBOOK.Z_PK
Ref: ZPAGE.server_user_id > users.id

// ─── Note Text Box ──────────────────────────────────────────

Table ZNOTETEXT {
  Z_PK INTEGER [pk]
  ZID TEXT [not null]
  ZPAGE INTEGER
  ZTEXT TEXT
  ZFONTSIZE REAL
  ZCOLORHEX TEXT
  ZX REAL
  ZY REAL
  ZWIDTH REAL
  ZHEIGHT REAL
  ZROTATION REAL
  ZZINDEX INTEGER
  ZISLOCKED INTEGER [default: 0]
  Z_ENT INTEGER
  Z_OPT INTEGER
  server_user_id INTEGER
}

Ref: ZNOTETEXT.ZPAGE > ZPAGE.Z_PK
Ref: ZNOTETEXT.server_user_id > users.id

