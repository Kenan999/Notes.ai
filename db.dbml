  ZOPACITY REAL
  ZISLOCKED INTEGER [default: 0]
  Z_ENT INTEGER
  Z_OPT INTEGER
  server_user_id INTEGER
}

Ref: ZNOTEIMAGE.ZPAGE > ZPAGE.Z_PK
Ref: ZNOTEIMAGE.server_user_id > users.id

